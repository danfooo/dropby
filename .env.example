# Server
PORT=3000
JWT_SECRET=change-me-in-production-use-long-random-string
NODE_ENV=development

# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# App URL (used for email links)
APP_URL=http://localhost:5173

# Admin dashboard (comma-separated)
# ADMIN_EMAILS=you@example.com

# Push notifications — fill in for production
# APNS_KEY_ID=          # Apple Developer → Certificates, IDs & Profiles → Keys
# APNS_TEAM_ID=         # Apple Developer → Membership → Team ID
# APNS_PRIVATE_KEY=     # Contents of the .p8 key file, newlines escaped as \n
# APNS_BUNDLE_ID=       # Defaults to cc.dropby.app
# FCM_PROJECT_ID=       # Firebase Console → Project Settings → General
# FCM_CLIENT_EMAIL=     # Firebase Console → Project Settings → Service Accounts → Generate new private key
# FCM_PRIVATE_KEY=      # From the downloaded service account JSON, newlines escaped as \n
# FCM_PRIVATE_KEY_ID=   # From the downloaded service account JSON
